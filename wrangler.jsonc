{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "map",
  "main": "_worker.js",
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "PARCEL_KV",
      "id": "d218db909ead4c1ab31a2a93fa33e7ef"
    }
  ],
  "observability": {
    "enabled": true
  }
}
